# Server Configuration
NODE_ENV=development
PORT=8080

# Database
MONGO_URI=
# OR for MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/flashbites?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key_change_this
JWT_REFRESH_EXPIRE=30d

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Razorpay Configuration (for India)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Google Maps API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Email Configuration - Mailtrap (Primary)
MAILTRAP_API_TOKEN=your_mailtrap_api_token
MAILTRAP_FROM_EMAIL=your_mailtrap_from_email
MAILTRAP_FROM_NAME=FlashBites

# Old Email Configuration (Mailjet - Backup)
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
MAILJET_FROM_EMAIL=

# Old Email Services (backup)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=your_app_specific_password
RESEND_API_KEY=

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Session Secret
SESSION_SECRET=your_session_secret_change_this_in_production

# Backend URL
BACKEND_URL=http://localhost:8080

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Admin Credentials (optional, for seeding)
ADMIN_EMAIL=admin@flashbites.com
ADMIN_PASSWORD=Admin@123456

# Firebase Admin SDK
#
# FIREBASE_PROJECT_ID — always set this to your Firebase project ID.
#
# FIREBASE_SERVICE_ACCOUNT_JSON — required in production (Railway, Render, etc.)
#   so the backend can verify phone-auth ID tokens and send push notifications.
#   Without it the server falls back to project-ID-only init, which will NOT be
#   able to verify user tokens and phone OTP login will fail.
#
# How to obtain the service account JSON:
#   1. Open Firebase Console → Project Settings → Service Accounts
#   2. Click "Generate new private key" and save the downloaded .json file
#   3. Minify / collapse the JSON to a single line (e.g. with `jq -c . key.json`)
#   4. Paste the entire single-line JSON string as the value below
#
# Note: newlines inside private_key must be literal \n (two chars), NOT a real
# newline.  The server automatically normalises them.
#
# Example:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project_id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your_project_id.iam.gserviceaccount.com"}
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=your_firebase_project_id

VAPID_PUBLIC_KEY = your_public_key
VAPID_PRIVATE_KEY = your_private_key

# For Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# OR for MSG91
MSG91_AUTH_KEY=your_key
MSG91_SENDER_ID=FLSHBT

RECAPTCHA_API_KEY=your_api_key_here

SMOKE_USER_PASSWORD=
SMOKE_USER_PHONE= 
SMOKE_USER_EMAIL= 