# API Configuration
VITE_API_URL=https://flashbites-backend.up.railway.app/api

# Google Maps API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Stripe (International)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Razorpay (India)
VITE_RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id

# App Info
VITE_APP_NAME=FlashBites
VITE_APP_VERSION=1.0.0

# ─── Firebase Configuration ───────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your Apps → FlashBites web app
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Optional: local-only phone OTP testing with Firebase fictional numbers
# Set to true only when testing on localhost with Firebase Auth test phone numbers.
VITE_FIREBASE_OTP_TEST_MODE=false

# Optional: allow real OTP from localhost (requires Firebase/Identity Platform
# reCAPTCHA and domain setup to be correct).
VITE_FIREBASE_ALLOW_LOCALHOST_REAL_OTP=false

VITE_FCM_VAPID_KEY=<your-key>